# Python 字节码缓存
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境
venv/
env/
.venv/

# 环境变量文件（包含敏感密钥）
.env

# SQLite 数据库文件
*.db
*.sqlite
*.sqlite3

# 日志文件
logs/
*.log

# IDE 配置文件（VSCode, PyCharm 等）
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统生成文件
.DS_Store
Thumbs.db

# 测试相关
.pytest_cache/
.coverage
htmlcov/

# 其他临时文件
*.tmp
*.bak